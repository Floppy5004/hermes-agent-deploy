# API Keys and Configuration for Hermes AI Agent

# --- General Core ---
AGENT_NAME="Hermes"
LOG_LEVEL="INFO"
MEMORY_TYPE="vector"

# --- Discord ---
DISCORD_TOKEN="your_discord_bot_token_here"
DISCORD_GUILD_ID="your_guild_id"
DISCORD_APPLICATION_ID="your_app_id"

# --- Telegram ---
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"

# --- Memory DB (ChromaDB) ---
CHROMA_HOST="memory-db"
CHROMA_PORT="8000"

# --- LLM Backend (Example: OpenAI or Local) ---
LLM_API_KEY="your_llm_api_key_here"
LLM_MODEL="gpt-4-turbo"
